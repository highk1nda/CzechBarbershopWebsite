# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase project settings (Project Settings -> API in the Supabase dashboard).
# The anon key is safe to expose client-side — it's constrained by Row Level Security.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# EmailJS (Account -> API Keys / Email Services / Email Templates in the EmailJS dashboard).
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
